# SQLite: path is relative to the prisma/ folder (creates prisma/dev.db).
DATABASE_URL="file:./dev.db"

# SMTP — email the host when a visitor checks in. Leave SMTP_HOST empty to disable (visits still save).
# Example (Mailtrap sandbox): host sandbox.smtp.mailtrap.io, port 2525, SMTP_SECURE=false
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="Visitor Register <noreply@example.com>"

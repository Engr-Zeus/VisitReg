generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Visitor {
  id           String    @id @default(cuid())
  firstName    String
  surname      String
  phone        String
  email        String
  organization String
  hostName     String
  hostEmail    String
  purpose      String
  notes        String    @default("")
  checkInAt    DateTime
  checkOutAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}
